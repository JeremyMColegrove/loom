// main.loom - The Robustness Stress Test
@import "std.csv" as csv
@import "std.out" as stdout
@import "logic" as util
// Setup the observer on the local inbox
@watch("./inbox/") as event >> filter(event.file.ext == "csv" && event.type == "created") >> @atomic >> [
    // Step 2: read the new file, parse it as csv
    @read(event.file.path) >> @csv.parse as data >> [
        // get all entries that are valid (func from other lib) and price matches
        filter(row >> util.is_valid(row) && row.price > 1000) as data >> [
            stdout,
            // print to screen
            data >> "premium_sales.csv",
            // append to file
            // append string to file
            \"Premium record processed: " >> "activity.log"
        ],
        // Sub-Branch B: another filter on csv data, apped to all_transactions
        filter(row >> util.is_valid(row)) >> "all_transactions.csv"
    ],
    // Step 3: move file to archive/...
    // if any steps in @atomic fails, do this
    event.file -> "./archive/" + event.file.name
] on_fail as err >> [
    // Step 4: Robust Rollback & Recovery
    // for error with func from othe rlib, append to error log
    util.format_alert(event.file.name, err) >> "error_log.txt",
    // move file
    event.file -> "./quarantine/"
]

