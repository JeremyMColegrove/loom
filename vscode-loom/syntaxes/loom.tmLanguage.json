{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loom",
  "scopeName": "source.loom",
  "patterns": [
    { "include": "#comment" },
    { "include": "#prefixed-string" },
    { "include": "#string" },
    { "include": "#directive" },
    { "include": "#keywords" },
    { "include": "#pipe" },
    { "include": "#move" },
    { "include": "#arrow" },
    { "include": "#operators" },
    { "include": "#boolean" },
    { "include": "#number" },
    { "include": "#function-call" },
    { "include": "#member-access" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.loom",
          "match": "//.*$"
        }
      ]
    },
    "prefixed-string": {
      "name": "string.quoted.double.prefixed.loom",
      "begin": "\\bs(\")",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.loom" }
      },
      "end": "(\")",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.loom" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.loom",
          "match": "\\\\."
        }
      ]
    },
    "string": {
      "name": "keyword.control.loom",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.loom",
          "match": "\\\\."
        }
      ]
    },
    "directive": {
      "patterns": [
        {
          "name": "entity.name.tag.directive.loom",
          "match": "@[A-Za-z][A-Za-z0-9_]*(?:\\.[A-Za-z][A-Za-z0-9_]*)*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.loom",
          "match": "\\b(?:as|on_fail|import)\\b"
        }
      ]
    },
    "pipe": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.loom",
          "match": ">>>|>>"
        }
      ]
    },
    "move": {
      "patterns": [
        {
          "name": "keyword.operator.move.loom",
          "match": "->"
        }
      ]
    },
    "arrow": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.loom",
          "match": "=>"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.loom",
          "match": "==|!="
        },
        {
          "name": "keyword.operator.arithmetic.loom",
          "match": "[+\\-*/!]"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.boolean.loom",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.loom",
          "match": "\\b-?(?:0|[1-9]\\d*)(?:\\.\\d+)?\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "captures": {
            "1": {
              "name": "entity.name.function.loom"
            }
          },
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.loom",
          "match": "\\b(?:filter|map|print|concat|exists)\\b"
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member-chain.loom",
          "match": "\\b[A-Za-z][A-Za-z0-9_]*(?:\\.[A-Za-z][A-Za-z0-9_]*)+\\b"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "name": "variable.other.loom",
          "match": "\\b[A-Za-z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
